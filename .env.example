# Supabase Configuration (Required for live data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-role-key

# FastAPI Security (Required)
# Use a strong, random string for production.
API_KEY=your-secret-api-key-here

# MLflow Tracking (Optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Backend Runner
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend (Vite) - Required for UI to Backend communication
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=your-secret-api-key-here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-role-key
